{
  "field_mapping": [
    {
      "source": "parsed.P_DTTM",
      "destination": "log_dttm"
    },
    {
      "source": "parsed.P_SERVICE",
      "destination": "service_name"
    },
    {
      "source": "parsed.P_LEVEL",
      "destination": "log_level"
    },
    {
      "source": "parsed.P_MESSAGE",
      "destination": "log_message"
    },
    {
      "source": "message",
      "destination": "raw_message"
    },
    {
      "source": "seqno",
      "destination": "seqno",
      "transform": "int64"
    },
    {
      "source": "syslog_identifier",
      "destination": "syslog_id"
    },
    {
      "source": "systemd_unit",
      "destination": "systemd_unit"
    },
    {
      "source": "log_timestamp_us",
      "destination": "log_timestamp_us",
      "transform": "timestamp64_us"
    },
    {
      "source": "message_cityhash64",
      "destination": "message_hash",
      "transform": "uint64"
    },
    {
      "source": "priority",
      "destination": "priority",
      "transform": "int"
    },
    {
      "source": "fields.CODE_FILE",
      "destination": "code_file",
      "default": "unknown"
    },
    {
      "source": "fields.CODE_LINE",
      "destination": "code_line",
      "transform": "int64",
      "default": "0"
    },
    {
      "source": "client_id",
      "destination": "client_id"
    }
  ]
}
