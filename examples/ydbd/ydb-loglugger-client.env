LOGLUGGER_SERVER_URL=https://loglugger-server.example:27312
LOGLUGGER_CLIENT_ID=%H
LOGLUGGER_SERVICE_MASK=regex:^ydbd-.*\\.service$
LOGLUGGER_BATCH_SIZE=50000
LOGLUGGER_BATCH_TIMEOUT=5s
LOGLUGGER_HTTP_TIMEOUT=30s
LOGLUGGER_RETRY_DELAY=1s
LOGLUGGER_TLS_CA_FILE=/opt/ydb/loglugger/certs/ca.crt
LOGLUGGER_TLS_CERT_FILE=/opt/ydb/loglugger/certs/client.crt
LOGLUGGER_TLS_KEY_FILE=/opt/ydb/loglugger/certs/client.key
