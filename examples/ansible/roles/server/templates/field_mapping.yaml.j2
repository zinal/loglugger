field_mapping:
  # Required key/identity fields for examples/ydbd/target_table.sql.
  - source: client_id
    destination: hostname
  - source: systemd_unit
    destination: unit
  - source: log_timestamp_us
    destination: ts_log
    transform: timestamp64_us
  - source: message_cityhash64
    destination: message_hash
    transform: uint64
  - source: seqno
    destination: seqno
    transform: int64

  # Optional data fields.
  - source: realtime_ts
    destination: ts_orig
    transform: timestamp64_us
  - source: parsed.P_DBNAME
    destination: dbname
    default: "-"
  - source: parsed.P_SERVICE
    destination: service
    default: unknown
  - source: parsed.P_LEVEL
    destination: level
    default: unknown
  - source: message
    destination: msg
  - source: parsed.P_MESSAGE
    destination: msg
    default: ""
